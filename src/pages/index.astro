---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
---

<script>
document.addEventListener("DOMContentLoaded", () => {
  const titleText = "Bienvenidos a Equipo 1";
  const subtitleText = "Innovación, Creatividad y Excelencia";

  let i = 0;
  let j = 0;

  const titleElement = document.getElementById("title");
  const subtitleElement = document.getElementById("subtitle");

  function typeTitle() {
    if (!titleElement) return;

    if (i < titleText.length) {
      titleElement.textContent += titleText[i];
      i++;
      setTimeout(typeTitle, 60);
    } else {
      setTimeout(typeSubtitle, 300);
    }
  }

  function typeSubtitle() {
    if (!subtitleElement) return;

    if (j < subtitleText.length) {
      subtitleElement.textContent += subtitleText[j];
      j++;
      setTimeout(typeSubtitle, 30);
    }
  }

  typeTitle();

  const bg = document.querySelector(".minecraft-bg");

if (bg) {
  for (let k = 0; k < 40; k++) {
    const pixel = document.createElement("span");
    pixel.style.left = Math.random() * 100 + "%";
    pixel.style.animationDuration = (5 + Math.random() * 10) + "s";
    pixel.style.opacity = Math.random();
    bg.appendChild(pixel);
  }
}


  
});
</script>

<Layout>
  <main class="main-content">
    
    <!-- HERO TERMINAL -->
    <section class="hero">
		<div class="conten">

			<div class="hero-overlay"></div>
			<div class="minecraft-bg"></div>
			
			<div class="hero-content">
				<p class="terminal-line">$ iniciando sistema...</p>
				<h1 class="hero-title" id="title"></h1>
				<p class="hero-subtitle" id="subtitle"></p>
			</div>
		</div>
    </section>

    <Welcome />

 
  </main>
</Layout>

<style>
.main-content {
  width: auto;
  
}

.conten {
  position: relative;
  width: auto;
  height: auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* HERO TERMINAL */
.hero {
  position: relative;
  width: 100%;
  height: 70vh;
  display: flex;
  padding: 5rem;
  gap: 30rem;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #111b1699;
  backdrop-filter: blur(5px);
  border: 2px solid #000000;
  border-radius: 15px;
  font-family: "Courier New", monospace;
}

/* EFECTO LUZ */
.hero-overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at top, rgba(246, 255, 250, 0.15)0.15), transparent 70%);
}

.hero-content {
  position: relative;
  z-index: 10;
  text-align: center;
}

/* TEXTO TERMINAL */
.hero-title {
  font-size: 3.5rem;
  font-weight: bold;
  color: #00ff9c;
  text-shadow: 0 0 10px rgba(0,255,150,0.8);
  margin: 0;
}

.hero-subtitle {
  font-size: 1.3rem;
  color: #8affc1;
  margin-top: 10px;
}

/* LINEA TERMINAL */
.terminal-line {
  color: #00ff9c;
  font-size: 1rem;
  margin-bottom: 10px;
  opacity: 0.7;
}

/* CURSOR */
.hero-title::after,
.hero-subtitle::after {
  content: "_";
  margin-left: 5px;
  animation: blink 1s infinite;
  color: #00ff9c;
}

@keyframes blink {
  50% { opacity: 0; }
}

/* FEATURES */
.features {
  padding: 6rem 2rem;
  background: linear-gradient(to bottom, #0d1117, #111827);
}

.features-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
}

.feature-card {
  background: #161b22;
  padding: 2rem;
  border-radius: 15px;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 5px 20px rgba(0, 255, 150, 0.05);
  color: white;
}

.feature-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 15px 40px rgba(0,255,150,0.2);
}

.feature-icon {
  font-size: 2rem;
  margin-bottom: 10px;1
}


//minecraft
.minecraft-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 1;
}

/* BLOQUES PIXEL */
.minecraft-bg::before,
.minecraft-bg::after {
  content: "";
  position: absolute;
  width: 200%;
  height: 200%;
  background-image:
    repeating-linear-gradient(
      0deg,
      rgba(0,255,150,0.08) 0px,
      rgba(0,255,150,0.08) 2px,
      transparent 2px,
      transparent 40px
    ),
    repeating-linear-gradient(
      90deg,
      rgba(0,255,150,0.08) 0px,
      rgba(0,255,150,0.08) 2px,
      transparent 2px,
      transparent 40px
    );
  animation: moveGrid 20s linear infinite;
}

/* CAPA MÁS LENTA */
.minecraft-bg::after {
  animation: moveGrid 10s linear infinite reverse;
  opacity: 0.4;
}

/* MOVIMIENTO */
@keyframes moveGrid {
  from {
    transform: translate(10px, 104px);
  }
  to {
    transform: translate(-600px, -500px);
  }
}
.minecraft-bg span {
  position: absolute;
  width: 8px;
  height: 8px;
  background: #00ff9c;
  box-shadow: 0 0 10px #00ff9c;
  animation: float 10s linear infinite;



}

@keyframes float {
  from {
    transform: translateY(100vh);
    opacity: 1;
  }
  to {
    transform: translateY(-100vh);
    opacity: 1;
  }
}
</style>